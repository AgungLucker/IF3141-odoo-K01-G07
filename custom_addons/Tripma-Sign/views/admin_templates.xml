<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         TRIPMA CUSTOM LAYOUT
         Menghilangkan navbar/footer Odoo dan menggantinya dengan milik kita.
    ============================================================ -->
    <record id="tripma_layout" model="ir.ui.view">
        <field name="name">Tripma Layout</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.tripma_layout</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.tripma_layout">
                <t t-call="website.layout">
                    <!-- Sembunyikan header dan footer bawaan Odoo -->
                    <t t-set="no_header" t-value="True"/>
                    <t t-set="no_footer" t-value="True"/>
                    
                    <!-- NAVBAR CUSTOM TRIPMA SIGN -->
                    <nav class="navbar navbar-expand-lg" style="background-color: #1E3A8A; padding: 15px 30px;">
                        <div class="container-fluid">
                            <a class="navbar-brand text-white fw-bold" href="/tripma">TRIPMA SIGN</a>
                            <div class="d-flex align-items-center">
                                <t t-if="user_role and user_role != 'unknown'">
                                    <span class="text-white me-3">Halo, <t t-esc="user_name"/></span>
                                    <a href="/web/session/logout?redirect=/tripma/login" class="btn btn-danger btn-sm">
                                        Logout
                                    </a>
                                </t>
                                <t t-else="">
                                    <a href="/tripma/login" class="btn btn-light btn-sm">Login</a>
                                </t>
                            </div>
                        </div>
                    </nav>

                    <!-- KONTEN HALAMAN -->
                    <div>
                        <t t-out="0"/>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         TRIPMA SIDEBAR LAYOUT (Khusus Dashboard Backend)
    ============================================================ -->
    <record id="tripma_sidebar_layout" model="ir.ui.view">
        <field name="name">Tripma Sidebar Layout</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.tripma_sidebar_layout</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.tripma_sidebar_layout">
                <t t-call="website.layout">
                    <!-- Sembunyikan header dan footer bawaan Odoo -->
                    <t t-set="no_header" t-value="True"/>
                    <t t-set="no_footer" t-value="True"/>
                    
                    <div style="display:flex; min-height:100vh;">
                        <!-- SIDEBAR -->
                        <aside class="ts-sidebar" style="width: 250px; background: var(--white); border-right: 1px solid var(--border); display: flex; flex-direction: column;">
                            <div style="padding:22px 20px; border-bottom:1px solid var(--border); margin-bottom:10px">
                                <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1.3rem;font-weight:800;color:var(--navy)">Tripma<span style="color:var(--gold)">Sign</span></div>
                                <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px">Aplikasi Bisnis</div>
                            </div>
                            
                            <div class="ts-sidebar-section" style="flex: 1;">
                                <div class="ts-sidebar-label" style="padding: 0 20px; font-size: 0.75rem; color: var(--text-muted); font-weight: 700; margin-bottom: 8px; text-transform: uppercase;">Utama</div>
                                
                                <t t-if="request.env.user.has_group('Tripma-Sign.group_tripma_admin')">
                                    <a href="/tripma/admin/dashboard" class="ts-sidebar-item active" style="display: flex; align-items: center; padding: 12px 20px; text-decoration: none; color: var(--navy); background: #e8eef5; font-weight: 600; border-right: 3px solid var(--navy); font-size: 0.9rem;">
                                        <span class="icon" style="margin-right: 12px;">📊</span> Panel Admin
                                    </a>
                                </t>
                                <t t-if="request.env.user.has_group('Tripma-Sign.group_tripma_production_staff')">
                                    <a href="/tripma/production" class="ts-sidebar-item active" style="display: flex; align-items: center; padding: 12px 20px; text-decoration: none; color: var(--navy); background: #e8eef5; font-weight: 600; border-right: 3px solid var(--navy); font-size: 0.9rem;">
                                        <span class="icon" style="margin-right: 12px;">🏷️</span> Dasbor Produksi
                                    </a>
                                </t>
                            </div>
                            
                            <!-- USER AREA DENGAN TOMBOL LOGOUT -->
                            <div class="ts-sidebar-user" style="padding: 20px; border-top: 1px solid var(--border); background: var(--bg);">
                                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                                    <div class="ts-avatar" style="width: 40px; height: 40px; border-radius: 50%; background: var(--navy); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem;">
                                        <t t-esc="(request.env.user.name or 'U')[0].upper()"/>
                                    </div>
                                    <div>
                                        <div class="ts-user-name" style="font-size: 0.9rem; font-weight: 700; color: var(--navy);"><t t-esc="request.env.user.name"/></div>
                                        <div class="ts-user-role" style="font-size: 0.75rem; color: var(--text-muted);">
                                            <t t-if="request.env.user.has_group('Tripma-Sign.group_tripma_admin')">Administrator</t>
                                            <t t-else="">Staf Produksi</t>
                                        </div>
                                    </div>
                                </div>
                                <a href="/web/session/logout?redirect=/tripma/login" class="btn btn-danger btn-sm" style="width: 100%; display: block; text-align: center;">
                                    Logout
                                </a>
                            </div>
                        </aside>
                        
                        <!-- MAIN CONTENT -->
                        <main style="flex: 1; overflow-y: auto; background: var(--bg);">
                            <t t-out="0"/>
                        </main>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         FR-04: Admin Dashboard (Simple Demo)
    ============================================================ -->
    <record id="admin_dashboard" model="ir.ui.view">
        <field name="name">Admin Dashboard</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.admin_dashboard</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.admin_dashboard">
                <t t-call="Tripma-Sign.tripma_sidebar_layout">
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            .ts-main { padding: 40px; background: var(--bg); min-height: calc(100vh - 57px); }
                            .ts-hero { background: var(--white); border-radius: var(--radius-lg); padding: 30px; box-shadow: var(--shadow-sm); border: 1px solid var(--border); margin-bottom: 24px; }
                            .ts-hero h1 { font-size: 1.5rem; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
                            .ts-hero p { color: var(--text-muted); font-size: 0.9rem; }
                        ]]></style>
                    </t>
                    
                    <div class="ts-main">
                        <div class="ts-hero">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h1>Selamat Datang di Dasbor Admin!</h1>
                                    <p>Anda mengakses sistem sebagai role: <strong><t t-esc="user_role"/></strong>.</p>
                                    <p class="mt-2 text-success"><strong>FR-04 (Access Control &amp; Routing) berfungsi dengan baik.</strong></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         FR-04: Halaman Akses Ditolak
         Ditampilkan saat user mencoba akses route tanpa izin.
    ============================================================ -->
    <record id="page_akses_ditolak" model="ir.ui.view">
        <field name="name">Akses Ditolak</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.page_akses_ditolak</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.page_akses_ditolak">
                <t t-call="Tripma-Sign.tripma_layout">
                    <div class="container d-flex flex-column align-items-center justify-content-center"
                         style="min-height: 70vh; text-align: center;">

                        <!-- Icon -->
                        <div style="font-size: 5rem; color: #dc3545; margin-bottom: 1.5rem;">
                            &#128274;
                        </div>

                        <h1 class="display-4 fw-bold" style="color: #212529;">
                            Akses Ditolak
                        </h1>
                        <p class="lead text-muted mt-3" style="max-width: 480px;">
                            Anda tidak memiliki izin untuk mengakses halaman ini.
                            Silakan hubungi administrator jika Anda merasa ini adalah kesalahan.
                        </p>

                        <!-- Info role (jika sudah login) -->
                        <t t-if="user_role and user_role != 'unknown'">
                            <div class="alert alert-warning mt-3" style="max-width: 400px;">
                                <strong>Role Anda:</strong>
                                <t t-if="user_role == 'admin'"> Admin Penjualan</t>
                                <t t-elif="user_role == 'production_staff'"> Staf Produksi</t>
                                <t t-elif="user_role == 'customer'"> Pelanggan</t>
                            </div>
                        </t>

                        <!-- Tombol navigasi sesuai role -->
                        <div class="mt-4 d-flex gap-3">
                            <t t-if="user_role == 'admin'">
                                <a href="/tripma/admin/dashboard" class="btn btn-primary btn-lg">
                                    Ke Dashboard Admin
                                </a>
                            </t>
                            <t t-elif="user_role == 'production_staff'">
                                <a href="/tripma/production" class="btn btn-primary btn-lg">
                                    Ke Dashboard Produksi
                                </a>
                            </t>
                            <t t-elif="user_role == 'customer'">
                                <a href="/tripma/pelanggan/pesanan" class="btn btn-primary btn-lg">
                                    Ke Pesanan Saya
                                </a>
                            </t>
                            <t t-else="">
                                <a href="/web/login?redirect=/tripma/login" class="btn btn-primary btn-lg">
                                    Login
                                </a>
                            </t>
                            <a href="/" class="btn btn-outline-secondary btn-lg">
                                Halaman Utama
                            </a>
                        </div>

                    </div>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         FR-04: HALAMAN LOGIN APLIKASI BISNIS
    ============================================================ -->
    <record id="tripma_login_page" model="ir.ui.view">
        <field name="name">Tripma Login Page</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.tripma_login_page</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.tripma_login_page">
                <t t-call="web.layout">
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            body { min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; background:var(--bg); }
                            .login-wrap { width:100%; max-width:480px; padding:24px; }
                            .brand-center { text-align:center; margin-bottom:32px; }
                            .brand-center .logo { font-family:'Plus Jakarta Sans',sans-serif; font-size:1.8rem; font-weight:800; color:var(--navy); }
                            .brand-center .logo em { color:var(--gold); font-style:normal; }
                            .brand-center p { color:var(--text-muted); font-size:0.95rem; margin-top:8px; }
                            .role-tabs { display:flex; background:var(--white); border:1px solid var(--border); border-radius:12px; padding:6px; gap:6px; margin-bottom:28px; }
                            .role-tab { flex:1; padding:12px; border-radius:8px; text-align:center; font-size:0.9rem; font-weight:600; cursor:pointer; transition:all 0.15s; color:var(--text-muted); }
                            .role-tab.active { background:var(--navy); color:white; }
                            .form-card { background:var(--white); border:1px solid var(--border); border-radius:16px; padding:32px; box-shadow:var(--shadow-lg); }
                            .forgot { text-align:right; margin-top:5px; }
                            .forgot a { font-size:0.75rem; color:var(--blue); text-decoration:none; }
                            .register-link { text-align:center; font-size:0.9rem; color:var(--text-muted); margin-top:24px; }
                            .register-link a { color:var(--navy); font-weight:600; text-decoration:none; }
                        ]]></style>
                    </t>
                    
                    <div class="login-wrap">
                        <div class="brand-center">
                            <div class="logo">Tripma<em>Sign</em></div>
                            <p>Masuk ke akun Aplikasi Bisnis Anda</p>
                        </div>

                        <!-- Role Selection (Hanya untuk Testing FR) -->
                        <div class="role-tabs">
                            <div class="role-tab" onclick="setDemoRole(this, 'customer')">👤 Pelanggan</div>
                            <div class="role-tab" onclick="setDemoRole(this, 'admin')">⚙️ Admin</div>
                            <div class="role-tab" onclick="setDemoRole(this, 'produksi')">🔧 Staf Produksi</div>
                        </div>

                        <div class="form-card">
                            <form role="form" action="/tripma/login" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                <!-- Notifikasi Error/Success Odoo -->
                                <t t-if="error">
                                    <div class="alert alert-danger" role="alert" style="border-radius: 8px;">
                                        <t t-esc="error"/>
                                    </div>
                                </t>
                                <t t-if="message">
                                    <div class="alert alert-success" role="alert" style="border-radius: 8px;">
                                        <t t-esc="message"/>
                                    </div>
                                </t>

                                <div class="ts-form-group">
                                    <label class="ts-label" for="login">Email / Username</label>
                                    <input type="text" name="login" t-att-value="login" id="login" class="ts-input" placeholder="contoh: admin" required="required" autofocus="autofocus" autocapitalize="off"/>
                                </div>
                                
                                <div class="ts-form-group">
                                    <label class="ts-label" for="password">Kata Sandi</label>
                                    <input type="password" name="password" id="password" class="ts-input" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096"/>
                                    <div class="forgot"><a href="/web/reset_password">Lupa kata sandi?</a></div>
                                </div>

                                <button type="submit" class="ts-btn ts-btn-primary ts-btn-block ts-btn-lg" style="margin-top:8px; width: 100%;">Masuk</button>
                            </form>
                        </div>
                        <div class="register-link">Belum punya akun? <a href="/tripma/register">Daftar sekarang</a></div>
                        <div style="text-align:center; margin-top:20px;">
                            <a href="/web/login" style="font-size: 0.85rem; color: #6c757d; text-decoration: underline;">Login Panel Konfigurasi Odoo (Admin IT)</a>
                        </div>
                    </div>
                    
                    <script>
                        function setDemoRole(el, role) {
                            // Highlight tab aktif
                            document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
                            el.classList.add('active');
                            
                            // Auto-fill form
                            const emailInput = document.getElementById('login');
                            const passInput = document.getElementById('password');
                            
                            if (role === 'customer') {
                                emailInput.value = 'cust';
                                passInput.value = '123';
                            } else if (role === 'admin') {
                                emailInput.value = 'admin';
                                passInput.value = 'admin';
                            } else if (role === 'produksi') {
                                emailInput.value = 'staf';
                                passInput.value = '123';
                            }
                        }
                    </script>
                </t>
            </t>
        </field>
    </record>

    <!-- ============================================================
         FR-04: HALAMAN REGISTRASI APLIKASI BISNIS
    ============================================================ -->
    <record id="tripma_register_page" model="ir.ui.view">
        <field name="name">Tripma Register Page</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.tripma_register_page</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.tripma_register_page">
                <t t-call="web.layout">
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            body { min-height:100vh; display:grid; grid-template-columns:1fr 1fr; }
                            .left-panel { background:var(--navy); padding:64px; display:flex; flex-direction:column; justify-content:center; }
                            .left-logo { font-family:'Plus Jakarta Sans',sans-serif; font-size:1.5rem; font-weight:800; color:white; margin-bottom:36px; }
                            .left-logo em { color:var(--gold-light); font-style:normal; }
                            .left-headline { font-size:1.6rem; font-weight:800; color:white; line-height:1.25; margin-bottom:14px; }
                            .left-sub { font-size:0.875rem; color:rgba(255,255,255,0.6); line-height:1.7; margin-bottom:40px; }
                            .feat-list { display:flex; flex-direction:column; gap:14px; }
                            .feat-item { display:flex; align-items:center; gap:12px; }
                            .feat-check { width:24px; height:24px; border-radius:6px; background:rgba(200,148,10,0.25); border:1px solid rgba(200,148,10,0.4); display:flex; align-items:center; justify-content:center; color:var(--gold-light); font-size:0.72rem; flex-shrink:0; }
                            .feat-text { font-size:0.85rem; color:rgba(255,255,255,0.7); }
                            .right-panel { background:var(--bg); display:flex; align-items:center; justify-content:center; padding:48px; }
                            .form-box { width:100%; max-width:420px; }
                            .form-box h2 { font-size:1.4rem; font-weight:800; color:var(--navy); margin-bottom:4px; }
                            .subtitle { font-size:0.85rem; color:var(--text-muted); margin-bottom:24px; }
                            .subtitle a { color:var(--navy); font-weight:600; text-decoration:none; }
                            .form-card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:24px; box-shadow:var(--shadow); }
                            .strength-bar { height:3px; background:var(--border); border-radius:3px; margin-top:6px; overflow:hidden; }
                            .strength-fill { height:100%; width:60%; background:var(--gold); border-radius:3px; }
                            .input-hint { font-size:0.72rem; color:var(--text-muted); margin-top:3px; }
                            .check-row { display:flex; align-items:flex-start; gap:9px; margin-bottom:20px; }
                            .check-row input { margin-top:2px; accent-color:var(--navy); }
                            .check-row label { font-size:0.8rem; color:var(--text-muted); }
                            .check-row label a { color:var(--navy); }
                            .divider-or { display:flex; align-items:center; gap:10px; color:var(--text-muted); font-size:0.78rem; margin:14px 0; }
                            .divider-or::before,.divider-or::after { content:""; flex:1; height:1px; background:var(--border); }
                            @media (max-width: 768px) {
                                body { grid-template-columns: 1fr; }
                                .left-panel { padding: 40px 24px; }
                                .right-panel { padding: 40px 24px; }
                            }
                        ]]></style>
                    </t>
                    
                    <div class="left-panel">
                        <div class="left-logo">Tripma<em>Sign</em></div>
                        <div class="left-headline">Mulai perjalanan signage Anda bersama kami</div>
                        <div class="left-sub">Buat akun gratis dan nikmati kemudahan memesan signage custom langsung dari browser Anda.</div>
                        <div class="feat-list">
                            <div class="feat-item"><div class="feat-check">✓</div><div class="feat-text">Pesan kapan saja, dari mana saja</div></div>
                            <div class="feat-item"><div class="feat-check">✓</div><div class="feat-text">Upload desain dan pantau produksi real-time</div></div>
                            <div class="feat-item"><div class="feat-check">✓</div><div class="feat-text">Invoice otomatis setiap pesanan dikonfirmasi</div></div>
                            <div class="feat-item"><div class="feat-check">✓</div><div class="feat-text">Riwayat pesanan tersimpan aman</div></div>
                        </div>
                    </div>
                    
                    <div class="right-panel">
                        <div class="form-box">
                            <h2>Buat Akun Baru</h2>
                            <p class="subtitle">Sudah punya akun? <a href="/tripma/login">Masuk di sini</a></p>
                            
                            <t t-if="error">
                                <div class="alert alert-danger" role="alert" style="border-radius: 8px; font-size: 0.85rem;">
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <div class="form-card">
                                <form action="/tripma/register/submit" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="ts-form-group">
                                        <label class="ts-label">Nama Lengkap <span class="req">*</span></label>
                                        <input type="text" name="name" t-att-value="name" class="ts-input" placeholder="Budi Santoso" required="required"/>
                                    </div>
                                    <div class="ts-form-group">
                                        <label class="ts-label">Alamat Email / Username <span class="req">*</span></label>
                                        <input type="text" name="login" t-att-value="login" class="ts-input" placeholder="budi@contoh.com" required="required" autocapitalize="off"/>
                                    </div>
                                    <div class="ts-form-group">
                                        <label class="ts-label">No. Telepon / WhatsApp</label>
                                        <input type="tel" name="phone" t-att-value="phone" class="ts-input" placeholder="08xxxxxxxxxx"/>
                                        <div class="input-hint">Untuk kemudahan komunikasi pesanan</div>
                                    </div>
                                    <div class="ts-form-group">
                                        <label class="ts-label">Kata Sandi <span class="req">*</span></label>
                                        <input type="password" name="password" class="ts-input" placeholder="Minimal 8 karakter" required="required"/>
                                    </div>
                                    <div class="ts-form-group">
                                        <label class="ts-label">Konfirmasi Kata Sandi <span class="req">*</span></label>
                                        <input type="password" name="confirm_password" class="ts-input" placeholder="Ulangi kata sandi" required="required"/>
                                    </div>
                                    <div class="check-row">
                                        <input type="checkbox" id="agree" required="required"/>
                                        <label for="agree">Saya menyetujui <a href="#">Syarat &amp; Ketentuan</a> Tripma Sign</label>
                                    </div>
                                    <button type="submit" class="ts-btn ts-btn-primary ts-btn-block ts-btn-lg" style="margin-bottom:14px; width:100%">Daftar Sekarang</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

</odoo>
