<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tripma_catalog_page" name="Katalog Produk">
        <t t-call="Tripma-Sign.tripma_layout">
            <t t-set="head">
                <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                <style>
                    .catalog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 20px 0; }
                    .product-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; transition: all 0.2s; }
                    .product-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
                    .product-img { height: 180px; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
                    .product-info { padding: 20px; }
                    .product-cat { font-size: 0.7rem; color: var(--gold); font-weight: 700; text-transform: uppercase; margin-bottom: 5px; }
                    .product-name { font-size: 1.1rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
                    .product-price { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 15px; }
                </style>
            </t>

            <div class="ts-page-header">
                <h1>Katalog Produk</h1>
                <p>Temukan signage yang sesuai kebutuhan bisnis Anda</p>
            </div>

            <div class="container my-5">
                <div class="catalog-grid">
                    <t t-foreach="products" t-as="product">
                        <div class="product-card">
                            <div class="product-img">
                                <t t-if="product.image">
                                    <img t-attf-src="data:image/png;base64,#{product.image}" style="height: 100%; width: 100%; object-fit: cover;"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="product.icon or '📦'"/>
                                </t>
                            </div>
                            <div class="product-info">
                                <div class="product-cat" t-esc="dict(product._fields['category'].selection).get(product.category)"/>
                                <div class="product-name" t-esc="product.name"/>
                                <div class="product-price">
                                    <t t-esc="'Rp {:,.0f}'.format(product.base_price)"/>
                                    <span style="font-size: 0.75rem; color: #666;"> / <t t-esc="'unit' if product.price_type == 'unit' else 'm²'"/></span>
                                </div>
                                <div class="product-desc mb-3" t-esc="product.description" style="font-size: 0.85rem; color: #666; height: 3em; overflow: hidden;"/>
                                <a t-attf-href="/tripma/order/form?product_id=#{product.id}" class="ts-btn ts-btn-primary w-100 text-center">Pesan Sekarang</a>
                            </div>
                        </div>
                    </t>

                    <!-- Custom Option -->
                    <div class="product-card" style="border: 2px dashed #ddd;">
                        <div class="product-img" style="background: #fff9eb;">✏️</div>
                        <div class="product-info">
                            <div class="product-cat" style="color: var(--gold);">Custom</div>
                            <div class="product-name">Signage Custom / Lainnya</div>
                            <div class="product-price" style="font-size: 0.8rem; color: #666; font-weight: 400;">Harga sesuai diskusi</div>
                            <div class="product-desc mb-3" style="font-size: 0.85rem; color: #666;">Punya ide unik di luar katalog? Ajukan permintaan custom di sini.</div>
                            <a href="/tripma/order/form" class="ts-btn ts-btn-secondary w-100 text-center">Ajukan Custom</a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
