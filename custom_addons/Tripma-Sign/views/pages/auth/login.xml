<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         FR-04: HALAMAN LOGIN APLIKASI BISNIS
    ============================================================ -->
    <record id="tripma_login_page" model="ir.ui.view">
        <field name="name">Tripma Login Page</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.tripma_login_page</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.tripma_login_page">
                <t t-call="Tripma-Sign.tripma_layout">
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            .login-page-container { min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--bg); padding: 40px 20px; }
                            .login-wrap { width: 100%; max-width: 480px; padding: 24px; }
                            .brand-center { text-align: center; margin-bottom: 32px; }
                            .brand-center p { color: var(--text-muted); font-size: 0.95rem; margin-top: 8px; }
                            .form-card { background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 32px; box-shadow: var(--shadow-lg); }
                            .forgot { text-align: right; margin-top: 5px; }
                            .forgot a { font-size: 0.75rem; color: var(--blue); text-decoration: none; }
                            .register-link { text-align: center; font-size: 0.9rem; color: var(--text-muted); margin-top: 24px; }
                            .register-link a { color: var(--navy); font-weight: 600; text-decoration: none; }
                        ]]></style>
                    </t>

                    <div class="login-page-container">
                        <div class="login-wrap">
                            <div class="brand-center">
                                <a href="/" style="display:inline-block; margin-bottom: 10px;">
                                    <img src="/Tripma-Sign/static/img/tripmalogo.png" alt="Tripma Sign Logo" style="height: 45px; width: auto; object-fit: contain;" />
                                </a>
                                <p>Masuk ke akun Aplikasi Bisnis Anda</p>
                            </div>

                            <div class="form-card">
                                <form role="form" action="/tripma/login" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <!-- Notifikasi Error/Success Odoo -->
                                    <t t-if="error">
                                        <div class="alert alert-danger" role="alert" style="border-radius: 8px;">
                                            <t t-esc="error"/>
                                        </div>
                                    </t>
                                    <t t-if="message">
                                        <div class="alert alert-success" role="alert" style="border-radius: 8px;">
                                            <t t-esc="message"/>
                                        </div>
                                    </t>

                                    <div class="ts-form-group">
                                        <label class="ts-label" for="login">Email / Username</label>
                                        <input type="text" name="login" t-att-value="login" id="login" class="ts-input" placeholder="contoh: admin" required="required" autofocus="autofocus" autocapitalize="off"/>
                                    </div>

                                    <div class="ts-form-group">
                                        <label class="ts-label" for="password">Kata Sandi</label>
                                        <input type="password" name="password" id="password" class="ts-input" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096"/>
                                        <div class="forgot"><a href="/web/reset_password">Lupa kata sandi?</a></div>
                                    </div>

                                    <button type="submit" class="ts-btn ts-btn-primary ts-btn-block ts-btn-lg" style="margin-top:8px; width: 100%;">Masuk</button>
                                </form>
                            </div>
                            <div class="register-link">Belum punya akun? <a href="/tripma/register">Daftar sekarang</a></div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>
