<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         FR-04: Admin Dashboard (Simple Demo)
    ============================================================ -->
    <record id="admin_dashboard" model="ir.ui.view">
        <field name="name">Admin Dashboard</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.admin_dashboard</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.admin_dashboard">
                <t t-call="Tripma-Sign.tripma_layout">
                    <t t-set="no_header" t-value="True"/>
                    <t t-set="no_footer" t-value="True"/>
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            .main-content { padding:28px 32px; background:var(--bg); }
                            .content-grid { display:grid; grid-template-columns:1fr 320px; gap:20px; }
                            .section-card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:18px; box-shadow:var(--shadow-sm); }
                            .card-header { padding:16px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
                            .card-title { font-size:0.875rem; font-weight:700; color:var(--navy); }
                            .card-action { font-size:0.78rem; color:var(--blue); text-decoration:none; }
                            .table-wrap { overflow-x:auto; }
                            .sidebar-card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:18px; box-shadow:var(--shadow-sm); }
                            .activity-item { display:flex; align-items:flex-start; gap:12px; padding:13px 18px; border-bottom:1px solid var(--border); }
                            .activity-item:last-child { border-bottom:none; }
                            .act-dot { width:8px; height:8px; border-radius:50%; margin-top:5px; flex-shrink:0; }
                            .act-navy { background:var(--navy); }
                            .act-gold { background:var(--gold); }
                            .act-green { background:var(--green); }
                            .act-blue { background:var(--blue); }
                            .act-text { font-size:0.8rem; color:var(--text); flex:1; line-height:1.4; }
                            .act-time { font-size:0.7rem; color:var(--text-muted); margin-top:2px; }
                            .quick-links { padding:16px; display:flex; flex-direction:column; gap:8px; }
                            .quick-link { display:flex; align-items:center; gap:12px; padding:12px 14px; border-radius:var(--radius); border:1px solid var(--border); text-decoration:none; transition:all 0.15s; }
                            .quick-link:hover { border-color:var(--navy); background:var(--bg); }
                            .ql-icon { width:34px; height:34px; border-radius:8px; background:#e8eef5; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
                            .ql-text-title { font-size:0.83rem; font-weight:600; color:var(--navy); }
                            .ql-text-sub { font-size:0.72rem; color:var(--text-muted); }
                        ]]></style>
                    </t>
                    <t t-set="additional_title">Dashboard Admin - Tripma Sign</t>

                    <div class="admin-shell">
                        <t t-set="active_menu" t-value="'dashboard'"/>
                        <t t-call="Tripma-Sign.admin_sidebar"/>

                        <div class="admin-page">
                            <div style="background:var(--white);border-bottom:1px solid var(--border);padding:14px 32px;display:flex;align-items:center;justify-content:space-between">
                                <div>
                                    <div style="font-size:1.1rem;font-weight:700;color:var(--navy)">Dashboard</div>
                                    <div style="font-size:0.78rem;color:var(--text-muted)">Ringkasan Bisnis</div>
                                </div>
                                <a href="/tripma/admin/external-order" class="ts-btn ts-btn-primary ts-btn-sm">+ Input Pesanan Eksternal</a>
                            </div>

                            <div class="main-content">
                                <div class="ts-stat-grid">
                                    <div class="ts-stat-card"><div class="ts-stat-header"><div><div class="ts-stat-value"><t t-esc="waiting_count + draft_count + queue_count"/></div><div class="ts-stat-label">Pesanan Perlu Diproses</div></div><div class="ts-stat-icon ts-stat-icon-navy">📥</div></div><span class="ts-badge ts-badge-blue">Tunggu Bayar / Antrian</span></div>
                                    <div class="ts-stat-card"><div class="ts-stat-header"><div><div class="ts-stat-value"><t t-esc="prod_count"/></div><div class="ts-stat-label">Sedang Diproduksi</div></div><div class="ts-stat-icon ts-stat-icon-gold">⚙️</div></div><span class="ts-badge ts-badge-gold">Proses aktif produksi</span></div>
                                    <div class="ts-stat-card"><div class="ts-stat-header"><div><div class="ts-stat-value"><t t-esc="done_count"/></div><div class="ts-stat-label">Siap Dikirim / Selesai</div></div><div class="ts-stat-icon ts-stat-icon-green">📦</div></div><span class="ts-badge ts-badge-green">Menunggu pickup</span></div>
                                    <div class="ts-stat-card"><div class="ts-stat-header"><div><div class="ts-stat-value"><t t-esc="total_orders"/></div><div class="ts-stat-label">Total Semua Pesanan</div></div><div class="ts-stat-icon ts-stat-icon-blue">📊</div></div><span class="ts-badge ts-badge-navy">Keseluruhan</span></div>
                                </div>

                                <div class="content-grid mt-4">
                                    <div>
                                        <div class="section-card">
                                            <div class="card-header"><div class="card-title">Pesanan Terkini</div><a href="/tripma/admin/semua-pesanan" class="card-action">Lihat semua →</a></div>
                                            <div class="table-wrap">
                                                <table class="ts-table" style="width: 100%; border-collapse: collapse;">
                                                    <thead style="background: var(--bg); font-size: 0.8rem; color: var(--text-muted); text-align: left;">
                                                        <tr>
                                                            <th style="padding: 12px 16px;">No. Order</th>
                                                            <th style="padding: 12px 16px;">Pelanggan</th>
                                                            <th style="padding: 12px 16px;">Produk</th>
                                                            <th style="padding: 12px 16px;">Status</th>
                                                            <th style="padding: 12px 16px;">Total</th>
                                                            <th style="padding: 12px 16px;">Aksi</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-if="not recent_orders">
                                                            <tr>
                                                                <td colspan="6" style="padding: 16px; text-align: center; color: var(--text-muted);">Belum ada pesanan terkini</td>
                                                            </tr>
                                                        </t>
                                                        <t t-foreach="recent_orders" t-as="order">
                                                            <tr style="border-bottom: 1px solid var(--border);">
                                                                <td style="padding: 12px 16px; font-weight: 600; color: var(--navy);"><t t-esc="order.name"/></td>
                                                                <td style="padding: 12px 16px;"><t t-esc="order.customer_id.name or '-'"/></td>
                                                                <td style="padding: 12px 16px;">
                                                                    <t t-if="order.product_specs">
                                                                        <t t-esc="order.product_specs.split('\n')[0] if '\n' in order.product_specs else order.product_specs"/>
                                                                    </t>
                                                                    <t t-else="">-</t>
                                                                </td>
                                                                <td style="padding: 12px 16px;">
                                                                    <t t-if="order.state == 'draft'"><span class="ts-badge ts-badge-blue">Draft</span></t>
                                                                    <t t-elif="order.state == 'waiting_payment'"><span class="ts-badge ts-badge-blue">Menunggu Pembayaran</span></t>
                                                                    <t t-elif="order.state == 'in_queue'"><span class="ts-badge ts-badge-gold">Antrian</span></t>
                                                                    <t t-elif="order.state == 'in_production'"><span class="ts-badge ts-badge-gold">Produksi</span></t>
                                                                    <t t-elif="order.state == 'done'"><span class="ts-badge ts-badge-green">Siap Kirim / Selesai</span></t>
                                                                    <t t-else=""><span class="ts-badge ts-badge-navy"><t t-esc="order.state"/></span></t>
                                                                </td>
                                                                <td style="padding: 12px 16px;">
                                                                    <t t-esc="order.currency_id.symbol or 'Rp'"/> <t t-esc="'{0:,.0f}'.format(order.billing_total).replace(',', '.')"/>
                                                                </td>
                                                                <td style="padding: 12px 16px;">
                                                                    <a t-attf-href="/tripma/production/update/{{order.id}}" style="font-size:0.78rem;color:var(--blue);text-decoration:none;">Detail</a>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                    <div>
                                        <div class="sidebar-card">
                                            <div class="card-header"><div class="card-title">Aksi Cepat</div></div>
                                            <div class="quick-links">
                                                <a href="/tripma/admin/external-order" class="quick-link"><div class="ql-icon">📥</div><div><div class="ql-text-title">Input Pesanan Eksternal</div><div class="ql-text-sub">WhatsApp / Walk-in</div></div></a>
                                                <a href="/tripma/admin/catalog" class="quick-link"><div class="ql-icon">🏷️</div><div><div class="ql-text-title">Kelola Katalog</div><div class="ql-text-sub">Tambah / edit produk</div></div></a>
                                                <a href="/tripma/admin/semua-pesanan" class="quick-link"><div class="ql-icon">📋</div><div><div class="ql-text-title">Semua Pesanan</div><div class="ql-text-sub">Lihat daftar lengkap pesanan</div></div></a>
                                                <!-- Opsi 3: Pintu ke backend untuk Admin -->
                                                <a href="/web" class="quick-link" t-if="is_tripma_admin"><div class="ql-icon">⚙️</div><div><div class="ql-text-title">Konfigurasi Sistem Odoo</div><div class="ql-text-sub">Akses backend untuk pengaturan user/database</div></div></a>
                                            </div>
                                        </div>

                                        <div class="sidebar-card">
                                            <div class="card-header"><div class="card-title">Aktivitas Sistem</div></div>
                                            <div class="activity-item"><div class="act-dot act-green"></div><div><div class="act-text">Sistem Dashboard Admin diakses oleh <strong><t t-esc="user_name"/></strong></div><div class="act-time">Baru saja</div></div></div>

                                            <t t-foreach="recent_activities" t-as="act">
                                                <div class="activity-item">
                                                    <div class="act-dot act-blue"></div>
                                                    <div>
                                                        <div class="act-text">Pesanan eksternal <strong style="text-transform: capitalize;"><t t-esc="act.source_channel"/></strong> dari <strong><t t-esc="act.customer_id.name"/></strong></div>
                                                        <div class="act-time"><t t-esc="act.create_date.strftime('%d %b %Y, %H:%M')"/></div>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

</odoo>
