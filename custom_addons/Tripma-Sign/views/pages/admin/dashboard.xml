<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         FR-04: Admin Dashboard (Simple Demo)
    ============================================================ -->
    <record id="admin_dashboard" model="ir.ui.view">
        <field name="name">Admin Dashboard</field>
        <field name="type">qweb</field>
        <field name="key">Tripma-Sign.admin_dashboard</field>
        <field name="arch" type="xml">
            <t t-name="Tripma-Sign.admin_dashboard">
                <t t-call="Tripma-Sign.tripma_layout">
                    <t t-set="no_header" t-value="True"/>
                    <t t-set="no_footer" t-value="True"/>
                    <t t-set="head">
                        <link rel="stylesheet" href="/Tripma-Sign/static/mockup/tripma.css"/>
                        <style><![CDATA[
                            .ts-main { padding: 40px; background: var(--bg); min-height: calc(100vh - 57px); }
                            .ts-hero { background: var(--white); border-radius: var(--radius-lg); padding: 30px; box-shadow: var(--shadow-sm); border: 1px solid var(--border); margin-bottom: 24px; }
                            .ts-hero h1 { font-size: 1.5rem; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
                            .ts-hero p { color: var(--text-muted); font-size: 0.9rem; }
                        ]]></style>
                    </t>
                    <t t-set="additional_title">Dashboard Admin - Tripma Sign</t>

                    <div class="admin-shell">
                        <t t-set="active_menu" t-value="'dashboard'"/>
                        <t t-call="Tripma-Sign.admin_sidebar"/>

                        <div class="admin-page">
                            <div class="admin-page-head">
                                <div class="admin-page-title">Dashboard Admin</div>
                            </div>

                            <div class="ts-main">
                                <!-- Stat cards -->
                                <div class="ts-stat-grid" style="margin-bottom: 24px;">
                                    <div class="ts-stat-card">
                                        <div class="ts-stat-header">
                                            <div>
                                                <div class="ts-stat-value" t-esc="total_orders"/>
                                                <div class="ts-stat-label">Total Pesanan</div>
                                            </div>
                                            <div class="ts-stat-icon ts-stat-icon-blue">📦</div>
                                        </div>
                                    </div>
                                    <div class="ts-stat-card">
                                        <div class="ts-stat-header">
                                            <div>
                                                <div class="ts-stat-value" t-esc="waiting_count"/>
                                                <div class="ts-stat-label">Menunggu Bayar</div>
                                            </div>
                                            <div class="ts-stat-icon ts-stat-icon-red">💳</div>
                                        </div>
                                    </div>
                                    <div class="ts-stat-card">
                                        <div class="ts-stat-header">
                                            <div>
                                                <div class="ts-stat-value" t-esc="queue_count"/>
                                                <div class="ts-stat-label">Antri Produksi</div>
                                            </div>
                                            <div class="ts-stat-icon ts-stat-icon-gold">⏳</div>
                                        </div>
                                    </div>
                                    <div class="ts-stat-card">
                                        <div class="ts-stat-header">
                                            <div>
                                                <div class="ts-stat-value" t-esc="prod_count"/>
                                                <div class="ts-stat-label">Sedang Diproduksi</div>
                                            </div>
                                            <div class="ts-stat-icon ts-stat-icon-blue">⚙️</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card p-4 shadow-sm border-0">
                                    <h5 class="fw-bold mb-4" style="color: var(--navy);">Navigasi Cepat</h5>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <a href="/tripma/admin/external-order" class="btn btn-outline-primary w-100 p-3 text-start">
                                                <div class="fw-bold">📥 Input Pesanan Eksternal</div>
                                                <small class="text-muted">Input dari WA / Offline</small>
                                            </a>
                                        </div>
                                        <div class="col-md-4">
                                            <a t-attf-href="/web#action=#{request.env.ref('Tripma-Sign.action_tripma_product_catalog').id}" class="btn btn-outline-primary w-100 p-3 text-start">
                                                <div class="fw-bold">🏷️ Kelola Katalog</div>
                                                <small class="text-muted">Update produk &amp; harga</small>
                                            </a>
                                        </div>
                                        <div class="col-md-4">
                                            <a href="/tripma/production" class="btn btn-outline-primary w-100 p-3 text-start">
                                                <div class="fw-bold">🏭 Dashboard Produksi</div>
                                                <small class="text-muted">Lihat antrian bengkel</small>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 alert alert-success d-flex align-items-center">
                                    <div class="me-3" style="font-size: 1.5rem;">🛡️</div>
                                    <div>
                                        <div class="fw-bold">Sistem Otoritas Berfungsi</div>
                                        <small>Data yang Anda lihat di atas dibatasi secara otomatis oleh <strong>ir.rule (Record Rules)</strong> berdasarkan role Anda sebagai <t t-esc="user_role"/>.</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </field>
    </record>

</odoo>
