<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Products -->
    <record id="view_tripma_product_tree" model="ir.ui.view">
        <field name="name">tripma.product.tree</field>
        <field name="model">tripma.product</field>
        <field name="arch" type="xml">
            <tree string="Katalog Produk">
                <field name="sequence" widget="handle"/>
                <field name="icon"/>
                <field name="name"/>
                <field name="category"/>
                <field name="base_price"/>
                <field name="price_type"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Products -->
    <record id="view_tripma_product_form" model="ir.ui.view">
        <field name="name">tripma.product.form</field>
        <field name="model">tripma.product</field>
        <field name="arch" type="xml">
            <form string="Produk Signage">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Nama Produk..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="icon"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="base_price"/>
                            <field name="price_type"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi">
                            <field name="description" placeholder="Berikan deskripsi produk yang menarik..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_tripma_product_catalog" model="ir.actions.act_window">
        <field name="name">Kelola Katalog Produk</field>
        <field name="res_model">tripma.product</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada produk di katalog.
            </p>
            <p>
                Tambahkan produk signage seperti Neon Sign, Acrylic, atau Banner agar pelanggan dapat memesan secara mandiri.
            </p>
        </field>
    </record>
</odoo>
