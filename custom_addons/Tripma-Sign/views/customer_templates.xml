<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="tripma_register_page" name="Tripma Register">
            <t t-call="website.layout">
                <div class="container mt-5 mb-5">
                    <div class="row justify-content-center">
                        <div class="col-md-6 card p-4 shadow-sm">
                            <h3 class="text-center mb-4">Daftar Akun Tripma Sign</h3>
                            <t t-if="error">
                                <p class="alert alert-danger"><t t-esc="error"/></p>
                            </t>
                            <form action="/tripma/register/submit" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-3">
                                    <label>Nama Lengkap *</label>
                                    <input type="text" name="name" class="form-control" required="1" t-att-value="name"/>
                                </div>
                                <div class="mb-3">
                                    <label>Email / Username *</label>
                                    <input type="text" name="login" class="form-control" required="1" t-att-value="login"/>
                                </div>
                                <div class="mb-3">
                                    <label>Nomor Telepon</label>
                                    <input type="text" name="phone" class="form-control" t-att-value="phone"/>
                                </div>
                                <div class="mb-3">
                                    <label>Kata Sandi *</label>
                                    <input type="password" name="password" class="form-control" required="1"/>
                                </div>
                                <div class="mb-3">
                                    <label>Konfirmasi Kata Sandi *</label>
                                    <input type="password" name="confirm_password" class="form-control" required="1"/>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Daftar Sekarang</button>
                            </form>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <template id="tripma_order_form_template" name="Form Order">
            <t t-call="website.layout">
                <div class="container mt-4">
                    <h2>Buat Pesanan Baru</h2>
                    <form action="/tripma/order/submit" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="card p-4">
                            <div class="mb-3">
                                <label>Nama Pemesan</label>
                                <input type="text" class="form-control" t-att-value="customer.name" readonly="1"/>
                            </div>
                            <div class="mb-3">
                                <label>Spesifikasi Produk (Ukuran, Bahan, Warna) *</label>
                                <textarea name="product_specs" class="form-control" rows="4" placeholder="Contoh: Acrylic Signage 30x40cm, warna biru laut..." required="1"></textarea>
                            </div>
                            <div class="mb-3">
                                <label>Upload Referensi Desain (.jpg, .png, .pdf)</label>
                                <input type="file" name="design_file" class="form-control"/>
                            </div>
                            <button type="submit" class="btn btn-success btn-lg">Kirim Pesanan &amp; Terbitkan Tagihan</button>
                        </div>
                    </form>
                </div>
            </t>
        </template>

        <template id="tripma_order_success_template" name="Order Berhasil">
            <t t-call="website.layout">
                <div class="container mt-5 text-center">
                    <div class="alert alert-success">
                        <h4>Pesanan Berhasil Dibuat!</h4>
                        <p>Nomor Pesanan Anda: <strong><t t-esc="order.name"/></strong></p>
                    </div>
                    <div class="card mt-4 p-4 shadow">
                        <h5>Rincian Tagihan (Invoice)</h5>
                        <p>ID Invoice: <t t-esc="invoice.name"/></p>
                        <p>Status Pembayaran: <span class="badge bg-warning text-dark"><t t-esc="invoice.payment_status"/></span></p>
                        <hr/>
                        <a t-attf-href="/tripma/track/#{order.name}" class="btn btn-primary">Lacak Status Produksi</a>
                        <a href="/tripma/pelanggan/pesanan" class="btn btn-outline-secondary">Kembali ke Daftar Pesanan</a>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>