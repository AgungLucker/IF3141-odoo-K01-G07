<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             MODULE CATEGORY
        ============================================================ -->

        <record id="module_category_tripma" model="ir.module.category">
            <field name="name">Tripma Sign</field>
            <field name="sequence">100</field>
        </record>

        <!-- ============================================================
             BASE USER GROUP
        ============================================================ -->

        <record id="group_tripma_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_tripma"/>

            <!-- Internal user -->
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ============================================================
             CUSTOMER
        ============================================================ -->

        <record id="group_tripma_customer" model="res.groups">
            <field name="name">Customer</field>
            <field name="category_id" ref="module_category_tripma"/>

            <!-- Portal access -->
            <field name="implied_ids" eval="[
                (4, ref('base.group_portal'))
            ]"/>
        </record>

        <!-- ============================================================
             PRODUCTION STAFF
        ============================================================ -->

        <record id="group_tripma_production_staff" model="res.groups">
            <field name="name">Staf Produksi</field>
            <field name="category_id" ref="module_category_tripma"/>

            <!-- Internal user -->
            <field name="implied_ids" eval="[
                (4, ref('group_tripma_user'))
            ]"/>
        </record>

        <!-- ============================================================
             ADMIN
        ============================================================ -->

        <record id="group_tripma_admin" model="res.groups">
            <field name="name">Admin Penjualan</field>
            <field name="category_id" ref="module_category_tripma"/>

            <!-- Full system administrator -->
            <field name="implied_ids" eval="[
                (4, ref('base.group_system')),
                (4, ref('group_tripma_user'))
            ]"/>

            <!-- Automatically assign built-in admin -->
            <field name="users" eval="[
                (4, ref('base.user_admin'))
            ]"/>
        </record>

    </data>
</odoo>