<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_tripma" model="ir.module.category">
            <field name="name">Tripma Sign</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_tripma_customer" model="res.groups">
            <field name="name">Customer</field>
            <field name="category_id" ref="module_category_tripma"/>
        </record>

        <record id="group_tripma_admin" model="res.groups">
            <field name="name">Admin Penjualan</field>
            <field name="category_id" ref="module_category_tripma"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_tripma_production_staff" model="res.groups">
            <field name="name">Staf Produksi</field>
            <field name="category_id" ref="module_category_tripma"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
