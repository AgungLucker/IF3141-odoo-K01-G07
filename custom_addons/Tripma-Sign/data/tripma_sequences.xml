<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_tripma_order" model="ir.sequence">
            <field name="name">Tripma Order Sequence</field>
            <field name="code">tripma.order</field>
            <field name="prefix">TS-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tripma_invoice" model="ir.sequence">
            <field name="name">Tripma Invoice Sequence</field>
            <field name="code">tripma.invoice</field>
            <field name="prefix">INV-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_tripma_production_status" model="ir.sequence">
            <field name="name">Tripma Production Status Sequence</field>
            <field name="code">tripma.production.status</field>
            <field name="prefix">PROD-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="use_date_range">False</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
