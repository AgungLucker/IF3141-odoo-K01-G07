<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="user_staf_produksi" model="res.users">
            <field name="name">Staf Produksi</field>
            <field name="login">staf</field>
            <field name="password">123</field>
            <!-- Explicitly assign both Tripma role AND Odoo Internal User type -->
            <field name="groups_id" eval="[
                (6, 0, [
                    ref('Tripma-Sign.group_tripma_production_staff'),
                    ref('base.group_user')
                ])
            ]"/>
        </record>

        <!-- Explicitly assign Admin to the Tripma Admin role -->
        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('Tripma-Sign.group_tripma_admin'))]"/>
        </record>

    </data>
</odoo>
